# =============================================================================
# Infrastructure Environment Variables - Centrifungal
# =============================================================================
# Set these in Railway's service variables (Dashboard > Service > Variables).

# Application
APP_KEY=
APP_ENV=production
APP_URL=https://api.centrifungal.co.uk
APP_DEBUG=false

# Database - SQLite on persistent volume
DB_CONNECTION=sqlite
DB_DATABASE=/data/database.sqlite

# Stripe - Payment processing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend - Transactional email
RESEND_API_KEY=

# Royal Mail - Shipping API
ROYAL_MAIL_API_KEY=
ROYAL_MAIL_API_SECRET=

# Litestream - SQLite continuous replication to Cloudflare R2 (TASK-005)
# These must all be set for Litestream to start.
LITESTREAM_REPLICA_URL=s3://centrifungal-db-backups/production
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# S3/R2 Filesystem Disk - used by the daily backup command (TASK-006)
# Configure the 's3' disk in config/filesystems.php to use R2 credentials.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=centrifungal-db-backups
AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

# Contact form
CONTACT_FORM_RECIPIENT=

# Frontend origin - used for CORS (TASK-008)
FRONTEND_URL=https://centrifungal.co.uk
