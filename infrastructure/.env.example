# Application
APP_KEY=
APP_ENV=production
APP_URL=https://centrifungal.com
APP_DEBUG=false

# Database - SQLite on persistent volume
DB_CONNECTION=sqlite
DB_DATABASE=/data/database.sqlite

# Stripe - Payment processing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend - Transactional email
RESEND_API_KEY=

# Royal Mail - Shipping API
ROYAL_MAIL_API_KEY=
ROYAL_MAIL_API_SECRET=

# Litestream - SQLite replication to Cloudflare R2 (TASK-005)
LITESTREAM_REPLICA_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Contact form
CONTACT_FORM_RECIPIENT=
